# Meshtastic bridge configuration
# Copy to config/meshtastic/meshtastic.env and edit.

# Meshtastic device connection:
#   Serial: /dev/ttyUSB0
#   TCP:    192.168.x.x:4403  (Meshtastic TCP API)
MESH_DEVICE=/dev/ttyUSB0

# TAK Server host and CoT UDP port
TAK_HOST=localhost
TAK_PORT=8087

# Meshtastic channel name to forward (leave blank for all)
MESH_CHANNEL=

# Optional: ATAK call sign prefix for Meshtastic nodes
CALLSIGN_PREFIX=MESH-
