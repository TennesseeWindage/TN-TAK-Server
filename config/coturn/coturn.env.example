# coturn environment configuration
# Copy to config/coturn/coturn.env and edit.

# ── Server identity ───────────────────────────────────────────────────────
# Public IP of this coturn host.
# For Tailscale deployment: use the Tailscale IP (100.x.y.z)
# For Netbird deployment: use the Netbird peer IP
# For internet-facing deployment: use the public IPv4 address
COTURN_PUBLIC_IP=

# TURN realm (use your domain or hostname)
COTURN_REALM=tak.tennesseewindage.com

# ── Credentials ────────────────────────────────────────────────────────────
# TURN user credentials for TAK federation peers
# Format: user:password (plaintext; stored in turndb, not this file)
COTURN_TURN_USER=takfed
COTURN_TURN_PASS=

# ── Tennessee Windage hosted TURN ──────────────────────────────────────────
# If using Tennessee Windage's hosted TURN server instead of self-hosted,
# set these values and leave COTURN_PUBLIC_IP empty.
# Credentials are provisioned by Tennessee Windage on request.
TN_TURN_HOST=turn.tennesseewindage.com
TN_TURN_PORT=3478
TN_TURN_TLS_PORT=5349
TN_TURN_USER=
TN_TURN_PASS=
